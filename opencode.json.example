{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  },
  "$comment_models": "Configure your model provider here. Examples below.",
  "_examples_for_minimax_via_anthropic_compat": {
    "provider": {
      "anthropic": {
        "options": {
          "baseURL": "https://api.minimax.io/anthropic",
          "apiKey": "{env:MINIMAX_API_KEY}"
        },
        "models": {
          "MiniMax-M2.7": {}
        }
      }
    }
  }
}
